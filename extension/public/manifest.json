{
  "manifest_version": 3,
  "name": "AI Resume Truth Checker - Cover Letter Assistant",
  "description": "Detect job postings and generate personalized cover letters from your saved CV.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Generate cover letter"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.shine.com/*",
    "https://*.monster.com/*",
    "https://*.apna.co/*",
    "https://*.foundit.in/*",
    "https://*.glassdoor.com/*",
    "https://*.wellfound.com/*",
    "https://*.naukri.com/*",
    "https://*.internshala.com/*",
    "https://ai-resume-truth-checker.vercel.app/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.indeed.com/*",
        "https://*.shine.com/*",
        "https://*.monster.com/*",
        "https://*.apna.co/*",
        "https://*.foundit.in/*",
        "https://*.glassdoor.com/*",
        "https://*.wellfound.com/*",
        "https://*.naukri.com/*",
        "https://*.internshala.com/*"
      ],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
